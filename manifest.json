{
  "manifest_version": 3,
  "name": "Rosewash",
  "version": "0.1.0",
  "description": "A lightweight Rose Pine tint for harsh white web pages.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rosewash"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "src/content/theme.css"
      ],
      "js": [
        "src/content/core.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

